uaishou\",\"Alibaba\":\"Alibaba\",\"ByteDance\":\"ByteDance\"},\"modelDescriptions\":{\"replicate__kling_2_6\":\"High-quality video with audio generation and flexible aspect ratios.\",\"replicate__kling_3_0\":\"Cinematic video up to 15s with multi-shot, native audio.\",\"replicate__kling_3_0_omni\":\"Multimodal video with reference images, video editing, and audio.\",\"kling__kling_3_0\":\"Cinematic video up to 15s with multi-shot, native audio.\",\"kling__kling_3_0_omni\":\"Multimodal video with reference images, video editing, and audio.\",\"replicate__wan_2_6_t2v\":\"Text-to-video with multi-shot and audio sync support.\",\"gemini__veo_3_1\":\"Google's flagship video model with audio, I2V, and reference images.\",\"gemini__veo_3_1_fast\":\"Fast VEO 3.1 variant optimized for speed with audio and I2V support.\",\"replicate__veo_3_1\":\"VEO 3.1 via Replicate with audio and reference image support.\",\"replicate__veo_3_1_fast\":\"Fast VEO 3.1 variant with lower cost and audio support.\",\"replicate__wan_2_6_i2v\":\"Image-to-video with multi-shot and audio sync.\",\"replicate__minimax_video_01\":\"6-second video with prompt optimization and subject reference.\",\"replicate__video_01_director\":\"Director-style video with camera control and prompt optimization.\",\"replicate__video_01_live\":\"Live-action video style from a first frame image.\",\"replicate__hailuo_2_3\":\"High-quality video with first/last frame control.\",\"replicate__hailuo_2_3_fast\":\"Fast Hailuo variant with I2V-only mode.\",\"replicate__seedance_1_pro\":\"Pro-quality video up to 12s with first/last frame control.\",\"replicate__seedance_1_lite\":\"Budget-friendly video with reference image support.\",\"replicate__seedance_1_pro_fast\":\"Fast Seedance variant with I2V support.\",\"replicate__pixverse_v4_5\":\"Stylized video with anime, 3D, cyberpunk, and comic styles.\",\"replicate__omni_human_1_5\":\"Audio-driven human animation from a single image.\",\"replicate__latentsync\":\"Lip-sync audio onto existing video footage.\",\"replicate__grok_imagine_video\":\"Text/image-to-video and video editing with synchronized audio.\",\"ark__seedance_1_lite\":\"Budget-friendly video generation with fast inference.\",\"ark__seedance_1_pro_fast\":\"Fast Seedance variant with first-frame I2V support.\",\"ark__seedance_1_5_pro\":\"Seedance 1.5 Pro with audio generation via native Ark API.\",\"ark_cn__seedance_2_0\":\"Seedance 2.0 — multi-modal video with reference images, audio, and 4-15s duration.\",\"ark_cn__seedance_2_0_fast\":\"Seedance 2.0 Fast — same capabilities, faster generation.\",\"replicate__sora_2\":\"OpenAI Sora 2 — cinematic video generation at 720p.\",\"replicate__sora_2_pro\":\"OpenAI Sora 2 Pro — high-quality video generation at 720p or 1080p.\"}},\"chat\":{\"placeholder\":\"Describe what you want to create...\",\"shortcuts\":{\"send\":\"Enter to send\",\"newLine\":\"Shift + Enter for new line\"},\"empty\":{\"headline\":\"What do you want to make?\",\"subtitle\":\"Pick a starting point below, or describe your own vision.\"},\"promptSuggestions\":{\"musicVideo\":{\"title\":\"Music video\",\"description\":\"A cinematic music video — neon city streets, rain-slick pavement, slow-motion tracking shots\",\"prompt\":\"Cinematic music video shot at night in a neon-lit city, slow motion tracking shot of a stylish artist walking through rain-slick streets, crowds blurred in the background, dramatic lighting with teal and magenta neon reflections, shallow depth of field, film grain\"},\"productAd\":{\"title\":\"Product ad\",\"description\":\"A premium product ad — studio lighting, rotating hero shot, the product catching light as it turns\",\"prompt\":\"Premium product advertisement, hero shot of the product rotating slowly on a minimal pedestal, dramatic rim lighting, soft shadows, gradient backdrop, shallow depth of field, glossy reflective surface catching the key light, commercial photography style\"},\"shortFilm\":{\"title\":\"Short film\",\"description\":\"A s